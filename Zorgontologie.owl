            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">klacht beleving</rdfs:label>
        <skos:definition xml:lang="nl">Een proces, ervaren door een patient, dat alleen ervaren kan worden door die patient, welke verondersteld wordt klinisch relevant te zijn.</skos:definition>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/OGMS_0000031 -->

