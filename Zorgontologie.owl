<?xml version="1.0"?>
<rdf:RDF xmlns="http://onto.fairify.com#"
     xml:base="http://onto.fairify.com"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:sno="http://snomed.info/id/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:cito="http://purl.org/spar/cito/"
     xmlns:core="http://purl.obolibrary.org/obo/uberon/core#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:protege="http://protege.stanford.edu/plugins/owl/protege#"
     xmlns:subsets="http://purl.obolibrary.org/obo/ro/subsets#"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="http://onto.fairify.com#">
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/ogms/2021-08-19/ogms.owl"/>
        <owl:imports rdf:resource="http://www.w3.org/2006/time#2016"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://onto.fairify.com#hasCodeSystem -->

    <owl:ObjectProperty rdf:about="http://onto.fairify.com#hasCodeSystem">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000578"/>
        <rdfs:range rdf:resource="http://onto.fairify.com#CodeSystem"/>
        <rdfs:label xml:lang="en">has code system</rdfs:label>
        <rdfs:label xml:lang="nl">heeft coderingssysteem</rdfs:label>
        <skos:definition xml:lang="nl">Relateert een centraal geregistreerde identifier aan het coderingssysteem waarbinnen deze is gedefinieerd.</skos:definition>
        <skos:definition xml:lang="en">Relates a centrally registered identifier to the code system within which it is defined.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000050 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000050">
        <rdfs:label xml:lang="nl">deel van</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000051 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000051">
        <rdfs:label xml:lang="nl">heeft deel</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000055 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000055">
        <obo:IAO_0000115 xml:lang="en">Paraphrase of elucidation: a relation between a process and a realizable entity, where there is some material entity that is bearer of the realizable entity and participates in the process, and the realizable entity comes to be realized in the course of the process</obo:IAO_0000115>
        <rdfs:label xml:lang="en">realizes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000062 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000062">
        <obo:IAO_0000115 xml:lang="en">x is preceded by y if and only if the time point at which y ends is before or equivalent to the time point at which x starts. Formally: x preceded by y iff ω(y) &lt;= α(x), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">preceded by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000066 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000066">
        <rdfs:label xml:lang="en">occurs in</rdfs:label>
        <rdfs:label xml:lang="nl">vindt plaats in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000136 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000136">
        <rdfs:label xml:lang="en">is about</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000219 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000219">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000235"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <obo:IAO_0000115 xml:lang="en">A primitive, instance-level, relation obtaining between an information content entity and some portion of reality. Denotation is what happens when someone creates an information content entity E in order to specifically refer to something. The only relation between E and the thing is that E can be used to &apos;pick out&apos; the thing. This relation connects those two together. Freedictionary.com sense 3: To signify directly; refer to specifically</obo:IAO_0000115>
        <rdfs:label xml:lang="en">denotes</rdfs:label>
        <rdfs:label xml:lang="nl">duidt aan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000235 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000235">
        <rdfs:label xml:lang="en">denoted by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000056 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000056">
        <rdfs:label xml:lang="en">participates in</rdfs:label>
        <rdfs:label xml:lang="nl">participeert in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000057 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000057">
        <rdfs:label xml:lang="en">has participant</rdfs:label>
        <rdfs:label xml:lang="nl">heeft deelnemer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000080 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000080">
        <obo:IAO_0000115 xml:lang="en">a relation between a quality and an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:label xml:lang="en">quality of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000086 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000086">
        <rdfs:label xml:lang="en">has quality</rdfs:label>
        <rdfs:label xml:lang="nl">heeft kwaliteit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000087 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000087">
        <rdfs:label xml:lang="en">has role</rdfs:label>
        <rdfs:label xml:lang="nl">heeft rol</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000091 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000091">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000092"/>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a disposition, in which the disposition specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has disposition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000092 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000092">
        <obo:IAO_0000115 xml:lang="en">inverse of has disposition</obo:IAO_0000115>
        <rdfs:label xml:lang="en">disposition of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0001015 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0001015">
        <rdfs:label xml:lang="nl">is locatie van</rdfs:label>
        <rdfs:label xml:lang="en">is location of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002233 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002233">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <obo:IAO_0000115 xml:lang="en">p has input c iff: p is a process, c is a material entity, c is a participant in p, c is present at the start of p, and the state of c is modified during p.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has input</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002234 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002234">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <obo:IAO_0000115 xml:lang="en">p has output c iff c is a participant in p, c is present at the end of p, and c is not present in the same state at the beginning of p.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has output</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/IAO_0000577 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000577">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000578"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has identifier symbol</rdfs:label>
        <rdfs:label xml:lang="nl">heeft identifiersymbool</rdfs:label>
        <skos:definition xml:lang="nl">De tekenreekswaarde van een centraal geregistreerde identifier; bijv. &apos;C67&apos; voor een ICD-10 code.</skos:definition>
        <skos:definition xml:lang="en">The string value of a centrally registered identifier; e.g. &apos;C67&apos; for an ICD-10 code.</skos:definition>
    </owl:DatatypeProperty>


    <!-- http://purl.obolibrary.org/obo/IAO_0000004 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000004">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has measurement value</rdfs:label>
        <rdfs:label xml:lang="nl">heeft meetwaarde</rdfs:label>
        <skos:definition xml:lang="en">Relates a data item to its scalar numeric value. Used to record the quantified result of a measurement, such as a PROM score or BMI value, as a decimal literal. The interpretation of the value (unit, scale, direction) is determined by the type of the data item bearer.</skos:definition>
        <skos:definition xml:lang="nl">Relateert een gegevensitem aan zijn scalaire numerieke waarde. Gebruikt om het gekwantificeerde resultaat van een meting te registreren, zoals een PROM-score of BMI-waarde, als een decimaal getal. De interpretatie van de waarde (eenheid, schaal, richting) wordt bepaald door het type van het dragende gegevensitem.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://onto.fairify.com#BMIMeasurementDatum -->

    <owl:Class rdf:about="http://onto.fairify.com#BMIMeasurementDatum">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hasTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2006/time#Instant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">BMI measurement datum</rdfs:label>
        <rdfs:label xml:lang="nl">BMI meetgegeven</rdfs:label>
        <skos:definition xml:lang="en">A data item representing the calculated Body Mass Index of a patient at a specific point in time. BMI is not a quality of the patient; it is a ratio derived from measurements of mass (PATO_0000128) and length (PATO_0000122), computed as kg/m². The associated time instant captures the moment of measurement, enabling contextual use such as BMI at time of diagnosis or BMI at time of surgical intervention. Pattern consistent with OBI_0001169 (age since birth measurement datum).</skos:definition>
        <skos:definition xml:lang="nl">Een gegevensitem dat de berekende Body Mass Index van een patiënt op een specifiek tijdstip vertegenwoordigt. BMI is geen kwaliteit van de patiënt; het is een ratio afgeleid van metingen van massa (PATO_0000128) en lengte (PATO_0000122), berekend als kg/m². Het geassocieerde tijdstip legt het meetmoment vast, wat contextueel gebruik mogelijk maakt zoals BMI ten tijde van de diagnose of ten tijde van chirurgische interventie. Patroon consistent met OBI_0001169.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#CareLocation -->

    <owl:Class rdf:about="http://onto.fairify.com#CareLocation">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0001015"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#HealthcareOrganisation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">care location</rdfs:label>
        <rdfs:label xml:lang="nl">zorglocatie</rdfs:label>
        <skos:definition xml:lang="en">A physical site at which healthcare processes occur and which is associated with one or more healthcare organisations. A care location is a site, not an organisation.</skos:definition>
        <skos:definition xml:lang="nl">Een fysieke locatie waar zorgprocessen plaatsvinden, geassocieerd met één of meer zorginstellingen. Een zorglocatie is een fysieke plek, geen organisatie.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#CareProviderRole -->

    <owl:Class rdf:about="http://onto.fairify.com#CareProviderRole">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">care provider role</rdfs:label>
        <rdfs:label xml:lang="nl">zorgverlenerrol</rdfs:label>
        <skos:definition xml:lang="nl">De rol van een persoon als verlener van zorg in de context van een zorgproces.</skos:definition>
        <skos:definition xml:lang="en">The role of a person as a provider of healthcare in the context of a healthcare process.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#ClinicalAdmission -->

    <owl:Class rdf:about="http://onto.fairify.com#ClinicalAdmission">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000096"/>
        <rdfs:label xml:lang="en">clinical admission</rdfs:label>
        <rdfs:label xml:lang="nl">klinische opname</rdfs:label>
        <skos:definition xml:lang="en">A healthcare process during which a patient stays at a care location overnight or for an extended period, enabling continuous monitoring and treatment.</skos:definition>
        <skos:definition xml:lang="nl">Een zorgproces waarbij een patiënt voor een nacht of langere periode verblijft op een zorglocatie, met continue monitoring en behandeling.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#ClinicalStagingProcess -->

    <owl:Class rdf:about="http://onto.fairify.com#ClinicalStagingProcess">
        <rdfs:subClassOf rdf:resource="http://onto.fairify.com#StagingProcess"/>
        <rdfs:label xml:lang="en">clinical staging process</rdfs:label>
        <rdfs:label xml:lang="nl">klinisch stadiëringsproces</rdfs:label>
        <skos:definition xml:lang="en">A staging process based on clinical examination, imaging (e.g. CT, MRI, PET), endoscopy, and/or biopsy without surgical resection. Corresponds to the &apos;c&apos; prefix in TNM notation (cTNM). Typically performed before surgical treatment. Tumour extent is inferred from indirect evidence. The distinction from pathological staging is multi-dimensional: method (indirect observation vs. direct tissue examination), timing (pre-surgical vs. post-surgical), and epistemic status (inferred vs. directly measured); not axiomatised.</skos:definition>
        <skos:definition xml:lang="nl">Een stadiëringsproces gebaseerd op klinisch onderzoek, beeldvorming (bijv. CT, MRI, PET), endoscopie en/of biopsie zonder chirurgische resectie. Correspondeert met het &apos;c&apos;-prefix in TNM-notatie (cTNM). Doorgaans uitgevoerd vóór chirurgische behandeling. Tumoruitbreiding wordt afgeleid uit indirecte gegevens. Het onderscheid met pathologische stadiëring is meerdimensionaal: methode, tijdstip en epistemische status; niet geaxiomatiseerd.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#CodeSystem -->

    <owl:Class rdf:about="http://onto.fairify.com#CodeSystem">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">code system</rdfs:label>
        <rdfs:label xml:lang="nl">coderingssysteem</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that defines a set of codes and their meanings, used to classify or identify entities in a domain.</skos:definition>
        <skos:definition xml:lang="nl">Een informatiecontententiteit die een verzameling codes en hun betekenissen definieert, gebruikt om entiteiten in een domein te classificeren of te identificeren.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#Death -->

    <owl:Class rdf:about="http://onto.fairify.com#Death">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000035"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#DyingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">death</rdfs:label>
        <rdfs:label xml:lang="nl">overlijden</rdfs:label>
        <skos:definition xml:lang="nl">De procesbegrenzing die het onomkeerbaar ophouden van alle vitale functies markeert; de terminale begrenzing van het overlijdensproces. Heeft precies één geassocieerd tijdstip.</skos:definition>
        <skos:definition xml:lang="en">The process boundary marking the irreversible cessation of all vital functions of an organism; the terminal boundary of the dying process. Has exactly one associated time:Instant.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#Discharge -->

    <owl:Class rdf:about="http://onto.fairify.com#Discharge">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000035"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#ClinicalAdmission"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">discharge</rdfs:label>
        <rdfs:label xml:lang="nl">ontslag</rdfs:label>
        <skos:definition xml:lang="nl">De procesbegrenzing die het einde van een klinische opname markeert; het moment waarop de patiënt formeel ontslagen wordt uit de zorg van de opnemende instelling.</skos:definition>
        <skos:definition xml:lang="en">The process boundary marking the end of a clinical admission; the moment at which the patient formally leaves the care of the admitting institution.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#DistantMetastasis -->

    <owl:Class rdf:about="http://onto.fairify.com#DistantMetastasis">
        <rdfs:subClassOf rdf:resource="http://onto.fairify.com#TumourExtent"/>
        <rdfs:label xml:lang="en">distant metastasis</rdfs:label>
        <rdfs:label xml:lang="nl">verre metastasering</rdfs:label>
        <skos:definition xml:lang="nl">De fysieke aanwezigheid van maligne tumorcellen in organen of weefsels op afstand van de primaire tumor en buiten de regionale lymfklieren. Correspondeert met de M-component van het TNM-classificatiesysteem. M0 = afwezig; M1 = aanwezig. Subcategorieën zijn tumortype- en editie-specifiek; niet geaxiomatiseerd in deze ontologie.</skos:definition>
        <skos:definition xml:lang="en">The physical presence of malignant tumour cells in organs or tissues distant from the primary tumour and beyond the regional lymph nodes. Corresponds to the M component of the TNM classification system. M0 denotes absence; M1 denotes presence. Subcategories are tumour-type specific and TNM-edition specific; not axiomatised in this ontology.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#DyingProcess -->

    <owl:Class rdf:about="http://onto.fairify.com#DyingProcess">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dying process</rdfs:label>
        <rdfs:label xml:lang="nl">overlijdensproces</rdfs:label>
        <skos:definition xml:lang="nl">Het biologische proces dat leidt tot het onomkeerbaar ophouden van alle vitale functies van een organisme, eindigend met het overlijden.</skos:definition>
        <skos:definition xml:lang="en">The biological process leading to the irreversible cessation of all vital functions of an organism, ending at death.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#HealthcareOrganisation -->

    <owl:Class rdf:about="http://onto.fairify.com#HealthcareOrganisation">
        <rdfs:subClassOf rdf:resource="http://onto.fairify.com#Organisation"/>
        <rdfs:label xml:lang="en">healthcare organisation</rdfs:label>
        <rdfs:label xml:lang="nl">zorginstelling</rdfs:label>
        <skos:definition xml:lang="en">An organisation whose primary purpose is the delivery of health care to patients.</skos:definition>
        <skos:definition xml:lang="nl">Een organisatie waarvan het primaire doel de verlening van zorg aan patiënten is.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#HipFracture -->

    <owl:Class rdf:about="http://onto.fairify.com#HipFracture">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000102"/>
        <skos:closeMatch rdf:resource="http://snomed.info/id/263225007"/>
    </owl:Class>
    


    <!-- http://onto.fairify.com#Organisation -->

    <owl:Class rdf:about="http://onto.fairify.com#Organisation">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <rdfs:label xml:lang="nl">organisatie</rdfs:label>
        <rdfs:label xml:lang="en">organisation</rdfs:label>
        <skos:definition xml:lang="en">An object aggregate consisting of persons acting together toward a shared purpose, typically with a defined structure and governance.</skos:definition>
        <skos:definition xml:lang="nl">Een objectaggregaat bestaande uit personen die samenwerken met een gemeenschappelijk doel, doorgaans met een gedefinieerde structuur en bestuur.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#OutpatientVisit -->

    <owl:Class rdf:about="http://onto.fairify.com#OutpatientVisit">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000096"/>
        <rdfs:label xml:lang="en">outpatient visit</rdfs:label>
        <rdfs:label xml:lang="nl">poliklinisch bezoek</rdfs:label>
        <skos:definition xml:lang="en">A healthcare process in which a patient attends a care location for assessment or treatment without being admitted for an overnight stay.</skos:definition>
        <skos:definition xml:lang="nl">Een zorgproces waarbij een patiënt een zorglocatie bezoekt voor beoordeling of behandeling zonder klinische opname.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#PROMScore -->

    <owl:Class rdf:about="http://onto.fairify.com#PROMScore">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#PatientReportedOutcomeMeasure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">PROM score</rdfs:label>
        <rdfs:label xml:lang="nl">PROM score</rdfs:label>
        <skos:definition xml:lang="en">A data item that is part of a completed patient reported outcome measure and represents a quantified assessment of a specific quality inhering in a person, as reported by that person at a specific point in time.</skos:definition>
        <skos:definition xml:lang="nl">Een gegevensitem dat deel uitmaakt van een ingevulde patiënt gerapporteerde uitkomstmaat en een gekwantificeerde beoordeling vertegenwoordigt van een specifieke kwaliteit die inhereert in een persoon, zoals door die persoon zelf gerapporteerd op een specifiek tijdstip.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#PathologicalStagingProcess -->

    <owl:Class rdf:about="http://onto.fairify.com#PathologicalStagingProcess">
        <rdfs:subClassOf rdf:resource="http://onto.fairify.com#StagingProcess"/>
        <rdfs:label xml:lang="en">pathological staging process</rdfs:label>
        <rdfs:label xml:lang="nl">pathologisch stadiëringsproces</rdfs:label>
        <skos:definition xml:lang="en">A staging process based on histopathological examination of surgically resected tumour tissue. Corresponds to the &apos;p&apos; prefix in TNM notation (pTNM). Requires prior surgical removal of tumour tissue. Tumour extent is directly measured from excised tissue. The distinction from clinical staging is multi-dimensional: method (direct tissue examination vs. indirect observation), timing (post-surgical vs. pre-surgical), and epistemic status (directly measured vs. inferred); not axiomatised.</skos:definition>
        <skos:definition xml:lang="nl">Een stadiëringsproces gebaseerd op histopathologisch onderzoek van chirurgisch gereseceerd tumorweefsel. Correspondeert met het &apos;p&apos;-prefix in TNM-notatie (pTNM). Vereist voorafgaande chirurgische verwijdering van tumorweefsel. Tumoruitbreiding wordt direct gemeten aan gereseceerd weefsel. Het onderscheid met klinische stadiëring is meerdimensionaal: methode, tijdstip en epistemische status; niet geaxiomatiseerd.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#PatientReportedOutcomeMeasure -->

    <owl:Class rdf:about="http://onto.fairify.com#PatientReportedOutcomeMeasure">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#PROMScore"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">patient reported outcome measure</rdfs:label>
        <rdfs:label xml:lang="nl">patiënt gerapporteerde uitkomstmaat</rdfs:label>
        <skos:definition xml:lang="en">An information content entity representing a completed instance of a standardised self-report questionnaire, produced by a person at a specific point in time as the output of a PROM administration process. Contains one or more PROM scores as parts. Not to be confused with the instrument (PROMInstrument) which defines the questionnaire structure.</skos:definition>
        <skos:definition xml:lang="nl">Een informatiecontententiteit die een ingevulde instantie vertegenwoordigt van een gestandaardiseerde zelfrapportagevragenlijst, door een persoon ingevuld op een specifiek tijdstip als uitkomst van een PROM-afnameproces. Bevat één of meer PROM-scores als onderdelen. Niet te verwarren met het instrument (PROMInstrument) dat de structuur van de vragenlijst definieert.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#PatientRole -->

    <owl:Class rdf:about="http://onto.fairify.com#PatientRole">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">patient role</rdfs:label>
        <rdfs:label xml:lang="nl">patiëntrol</rdfs:label>
        <skos:definition xml:lang="nl">De rol van een persoon als ontvanger van zorg, inherent aan die persoon vanwege deelname aan een zorgproces.</skos:definition>
        <skos:definition xml:lang="en">The role of a person as a recipient of healthcare, inhering in that person by virtue of their participation in a healthcare process.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#PrimaryTumourExtent -->

    <owl:Class rdf:about="http://onto.fairify.com#PrimaryTumourExtent">
        <rdfs:subClassOf rdf:resource="http://onto.fairify.com#TumourExtent"/>
        <rdfs:label xml:lang="nl">primaire tumoruitbreiding</rdfs:label>
        <rdfs:label xml:lang="en">primary tumour extent</rdfs:label>
        <skos:definition xml:lang="nl">De fysieke uitbreiding van de primaire maligne tumor, gekenmerkt door grootte en mate van lokale weefselinfiltratie. Correspondeert met de T-component van het TNM-classificatiesysteem. Grenswaarden voor T-categorieën (T1 t/m T4) zijn tumortype- en editie-specifiek; niet geaxiomatiseerd in deze ontologie.</skos:definition>
        <skos:definition xml:lang="en">The physical extent of the primary malignant tumour, characterised by its size and degree of local tissue infiltration. Corresponds to the T component of the TNM classification system. The boundary criteria for T categories (T1 through T4) are tumour-type specific and TNM-edition specific; they are not axiomatised in this ontology.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#RegionalLymphNodeInvolvement -->

    <owl:Class rdf:about="http://onto.fairify.com#RegionalLymphNodeInvolvement">
        <rdfs:subClassOf rdf:resource="http://onto.fairify.com#TumourExtent"/>
        <rdfs:label xml:lang="en">regional lymph node involvement</rdfs:label>
        <rdfs:label xml:lang="nl">regionale lymfklierbetrokkenheid</rdfs:label>
        <skos:definition xml:lang="nl">De fysieke toestand van regionale lymfklieren met betrekking tot betrokkenheid door metastatische tumorcellen. Correspondeert met de N-component van het TNM-classificatiesysteem. Criteria voor N-categorieën zijn tumortype- en editie-specifiek; niet geaxiomatiseerd in deze ontologie.</skos:definition>
        <skos:definition xml:lang="en">The physical state of regional lymph nodes with respect to metastatic tumour cell involvement. Corresponds to the N component of the TNM classification system. Criteria for N categories are tumour-type specific and TNM-edition specific; not axiomatised in this ontology.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#StagingAssessment -->

    <owl:Class rdf:about="http://onto.fairify.com#StagingAssessment">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#TumourExtent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hasTime"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2006/time#Instant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">stadiëringsbeoordeling</rdfs:label>
        <rdfs:label xml:lang="en">staging assessment</rdfs:label>
        <skos:definition xml:lang="en">A data item recording the result of a staging process for a specific patient at a specific point in time. Is about (IAO_0000136) the tumour extent of the patient. The classification code (e.g. &apos;pT2N1M0&apos; or &apos;FIGO IIB&apos;) attaches via a CRID (IAO_0000578) that denotes this assessment. The mapping between code and modelled biological entities is tumour-type specific, staging-system specific, and edition specific; not axiomatised.</skos:definition>
        <skos:definition xml:lang="nl">Een gegevensitem dat het resultaat vastlegt van een stadiëringsproces voor een specifieke patiënt op een specifiek tijdstip. Gaat over (IAO_0000136) de tumoruitbreiding van de patiënt. De classificatiecode (bijv. &apos;pT2N1M0&apos; of &apos;FIGO IIB&apos;) wordt gekoppeld via een CRID (IAO_0000578) die deze beoordeling aanduidt. De mapping tussen code en gemodelleerde biologische entiteiten is tumortype-, stadiëringssysteem- en editie-specifiek; niet geaxiomatiseerd.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#StagingProcess -->

    <owl:Class rdf:about="http://onto.fairify.com#StagingProcess">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000104"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002234"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#StagingAssessment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">stadiëringsproces</rdfs:label>
        <rdfs:label xml:lang="en">staging process</rdfs:label>
        <skos:definition xml:lang="en">A diagnostic process whose objective is to determine the extent of a malignant neoplasm in a patient&apos;s body, resulting in a staging assessment that classifies the tumour extent according to a staging system such as TNM or FIGO.</skos:definition>
        <skos:definition xml:lang="nl">Een diagnostisch proces met als doel de uitbreiding van een maligne neoplasma in het lichaam van een patiënt vast te stellen, resulterend in een stadiëringsbeoordeling die de tumoruitbreiding classificeert volgens een stadiëringssysteem zoals TNM of FIGO.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#SurgicalProcedure -->

    <owl:Class rdf:about="http://onto.fairify.com#SurgicalProcedure">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000090"/>
        <rdfs:label xml:lang="nl">chirurgische ingreep</rdfs:label>
        <rdfs:label xml:lang="en">surgical procedure</rdfs:label>
        <skos:definition xml:lang="en">A treatment process in which a care provider manually or instrumentally intervenes in or on a patient&apos;s body for therapeutic purposes.</skos:definition>
        <skos:definition xml:lang="nl">Een behandelproces waarbij een zorgverlener manueel of instrumenteel ingrijpt in of op het lichaam van een patiënt met therapeutisch doel.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#THP -->

    <owl:Class rdf:about="http://onto.fairify.com#THP">
        <rdfs:subClassOf rdf:resource="http://onto.fairify.com#SurgicalProcedure"/>
        <rdfs:label xml:lang="nl">totale heup procedure</rdfs:label>
        <skos:closeMatch rdf:resource="http://snomed.info/id/52734007"/>
    </owl:Class>
    


    <!-- http://onto.fairify.com#TumourExtent -->

    <owl:Class rdf:about="http://onto.fairify.com#TumourExtent">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000045"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">tumoruitbreiding</rdfs:label>
        <rdfs:label xml:lang="en">tumour extent</rdfs:label>
        <skos:definition xml:lang="nl">De totale fysieke uitbreiding van een maligne neoplasma in het lichaam van een patiënt op een bepaald tijdstip, bestaande uit de primaire tumor, eventuele regionale lymfklierbetrokkenheid en eventuele verre metastasen. Dit is de biologische realiteit die stadiëringssystemen zoals TNM en FIGO classificeren en coderen.</skos:definition>
        <skos:definition xml:lang="en">The overall physical extent of a malignant neoplasm in a patient&apos;s body at a given point in time, comprising the primary tumour, any regional lymph node involvement, and any distant metastases. This is the biological reality that tumour staging systems such as TNM and FIGO classify and encode.</skos:definition>
    </owl:Class>
    


    <!-- http://onto.fairify.com#prosthesis -->

    <owl:Class rdf:about="http://onto.fairify.com#prosthesis">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="nl">prothese</rdfs:label>
        <skos:closeMatch rdf:resource="http://snomed.info/id/53350007"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000015 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hasTime"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#ProperInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">proces</rdfs:label>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000023 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000023">
        <rdfs:label xml:lang="nl">rol</rdfs:label>
        <rdfs:label xml:lang="en">role</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000027 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000027">
        <rdfs:label xml:lang="en">object aggregate</rdfs:label>
        <rdfs:label xml:lang="nl">objectaggregaat</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000029 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000029">
        <rdfs:label xml:lang="nl">locatie</rdfs:label>
        <rdfs:label xml:lang="en">site</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000035 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000035">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hasTime"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#Instant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">procesbegrenzing</rdfs:label>
        <rdfs:label xml:lang="en">process boundary</rdfs:label>
        <skos:definition xml:lang="en">An instantaneous temporal boundary of a process; either the moment at which the process begins or the moment at which it ends.</skos:definition>
        <skos:definition xml:lang="nl">Een instantane temporele begrenzing van een proces; het moment waarop het proces begint of eindigt.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000109 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000109">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:label xml:lang="en">measurement datum</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000578 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000578">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="nl">centraal geregistreerde identifier</rdfs:label>
        <rdfs:label xml:lang="en">centrally registered identifier</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that is the officially assigned identifier of some entity within the context of a particular identifier system.</skos:definition>
        <skos:definition xml:lang="nl">Een informatiecontententiteit die de officieel toegewezen identifier is van een entiteit binnen de context van een bepaald identificatiesysteem.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000582 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000582">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000109"/>
        <rdfs:label xml:lang="en">time stamped measurement datum</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0020000 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0020000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115 xml:lang="en">An information content entity that is the outcome of a dubbing process and is used to refer to one instance of entity shared by a group of people to refer to that individual entity.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/NCBITAXON_9606 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCBITAXON_9606">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000087"/>
        <rdfs:label xml:lang="en">homo sapiens</rdfs:label>
        <rdfs:label xml:lang="nl">mens</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000070 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000070">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000096"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002234"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">assay</rdfs:label>
        <rdfs:label xml:lang="nl">meting</rdfs:label>
        <skos:definition xml:lang="en">A planned process with the objective to produce information about a material entity by examining it.</skos:definition>
        <skos:definition xml:lang="nl">Een gepland proces met als doel informatie te produceren over een materiële entiteit door deze te onderzoeken.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001169 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0001169">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000109"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000011"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">age since birth measurement datum</rdfs:label>
        <rdfs:label xml:lang="nl">leeftijd vanaf geboorte meetgegeven</rdfs:label>
        <skos:definition xml:lang="nl">Het meetresultaat van een meting van de eigenschap leeftijd; gemeten vanaf geboorte.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OGMS_0000020 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000020">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000066"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">klacht beleving</rdfs:label>
        <skos:definition xml:lang="nl">Een proces, ervaren door een patient, dat alleen ervaren kan worden door die patient, welke verondersteld wordt klinisch relevant te zijn.</skos:definition>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/OGMS_0000031 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000031">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000062"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000045"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000092"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">ziekte</rdfs:label>
        <skos:definition xml:lang="nl">Een dispositie (i) om pathologische processen te ondergaan die (ii) in een organisme bestaat vanwege één of meer aandoeningen in dat organisme.</skos:definition>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/OGMS_0000045 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000045">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">fysieke afwijking</rdfs:label>
        <skos:definition xml:lang="nl">Een fysieke entiteit die klinisch abnormaal is en onderdeel van een extended organisme. Fysieke afwijkingen vormen de basis van een ziekte.</skos:definition>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/OGMS_0000063 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000063">
