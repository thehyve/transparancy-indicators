        <rdfs:label xml:lang="nl">leeftijd vanaf geboorte meetgegeven</rdfs:label>
        <skos:definition xml:lang="nl">Het meetresultaat van een meting van de eigenschap leeftijd; gemeten vanaf geboorte.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OGMS_0000020 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000020">
        <rdfs:subClassOf>
