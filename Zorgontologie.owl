            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">health care process</rdfs:label>
        <rdfs:label xml:lang="nl">zorgproces</rdfs:label>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/OGMS_0000104 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000104">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002234"/>
