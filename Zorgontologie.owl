        <rdfs:label xml:lang="nl">diagnose</rdfs:label>
        <skos:definition xml:lang="nl">De representatie van de conclusie van een diagnostisch proces</skos:definition>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/OGMS_0000090 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000090">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
