                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">diagnostisch proces</rdfs:label>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0000011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000011">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">age</rdfs:label>
        <rdfs:label xml:lang="nl">leeftijd</rdfs:label>
        <skos:definition xml:lang="en">A time quality inhering in a bearer by virtue of how long the bearer has existed.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0000047 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000047">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">biological sex</rdfs:label>
        <rdfs:label xml:lang="nl">biologisch geslacht</rdfs:label>
        <skos:definition xml:lang="en">A quality of an organism based on the reproductive organs and functions that derive from chromosomal complement.</skos:definition>
        <skos:definition xml:lang="nl">Een kwaliteit van een organisme gebaseerd op de reproductieve organen en functies die voortvloeien uit het chromosomale complement.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0000122 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000122">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="nl">lengte</rdfs:label>
        <rdfs:label xml:lang="en">length</rdfs:label>
        <skos:definition xml:lang="en">A quality of a material entity inhering in it by virtue of its spatial extent along its longest axis.</skos:definition>
        <skos:definition xml:lang="nl">Een kwaliteit van een materiële entiteit, inherent aan die entiteit vanwege haar ruimtelijke uitgestrektheid langs de langste as.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0000128 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000128">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">mass</rdfs:label>
        <rdfs:label xml:lang="nl">massa</rdfs:label>
        <skos:definition xml:lang="en">A quality of a material entity inhering in it by virtue of the amount of matter it contains.</skos:definition>
        <skos:definition xml:lang="nl">Een kwaliteit van een materiële entiteit, inherent aan die entiteit vanwege de hoeveelheid materie die ze bevat.</skos:definition>
    </owl:Class>
    


    <!-- http://www.w3.org/2006/time#ProperInterval -->

    <rdf:Description rdf:about="http://www.w3.org/2006/time#ProperInterval">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hasBeginning"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#Instant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2006/time#hasEnd"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#Instant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://onto.fairify.com#DBCCode -->

    <owl:NamedIndividual rdf:about="http://onto.fairify.com#DBCCode">
        <rdf:type rdf:resource="http://onto.fairify.com#CodeSystem"/>
        <rdfs:label xml:lang="en">DBC code</rdfs:label>
        <rdfs:label xml:lang="nl">DBC-code</rdfs:label>
        <skos:definition xml:lang="en">Diagnose Behandel Combinatie code; a Dutch administrative code combining diagnosis and treatment for reimbursement purposes.</skos:definition>
        <skos:definition xml:lang="nl">Diagnose Behandel Combinatie code; een Nederlandse administratieve code die diagnose en behandeling combineert voor declaratiedoeleinden.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- http://onto.fairify.com#FIGOSystem -->

    <owl:NamedIndividual rdf:about="http://onto.fairify.com#FIGOSystem">
        <rdf:type rdf:resource="http://onto.fairify.com#CodeSystem"/>
        <rdfs:label xml:lang="en">FIGO staging system</rdfs:label>
        <rdfs:label xml:lang="nl">FIGO-stadiëringssysteem</rdfs:label>
        <skos:definition xml:lang="nl">Het stadiëringssysteem van de FIGO, gebruikt voor gynaecologische maligniteiten. FIGO-stadia (I–IV met substadia) combineren PrimaryTumourExtent, RegionalLymphNodeInvolvement en DistantMetastasis tot één ordinale classificatie. Overlapt gedeeltelijk met TNM; mapping is tumortype- en editie-specifiek; niet geaxiomatiseerd.</skos:definition>
        <skos:definition xml:lang="en">The staging system of the International Federation of Gynecology and Obstetrics (FIGO), used for gynaecological malignancies. FIGO stages (I–IV with substages) combine PrimaryTumourExtent, RegionalLymphNodeInvolvement, and DistantMetastasis into a single ordinal classification. Partially overlaps with TNM; mapping is tumour-type specific and edition specific; not axiomatised.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- http://onto.fairify.com#ICD10 -->

    <owl:NamedIndividual rdf:about="http://onto.fairify.com#ICD10">
        <rdf:type rdf:resource="http://onto.fairify.com#CodeSystem"/>
        <rdfs:label xml:lang="en">ICD-10</rdfs:label>
        <rdfs:label xml:lang="nl">ICD-10</rdfs:label>
        <skos:definition xml:lang="en">International Classification of Diseases, 10th revision.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- http://onto.fairify.com#SNOMEDCT -->

    <owl:NamedIndividual rdf:about="http://onto.fairify.com#SNOMEDCT">
        <rdf:type rdf:resource="http://onto.fairify.com#CodeSystem"/>
        <rdfs:label xml:lang="en">SNOMED CT</rdfs:label>
        <rdfs:label xml:lang="nl">SNOMED CT</rdfs:label>
        <skos:definition xml:lang="en">Systematized Nomenclature of Medicine – Clinical Terms.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- http://onto.fairify.com#TNMSystem -->

    <owl:NamedIndividual rdf:about="http://onto.fairify.com#TNMSystem">
        <rdf:type rdf:resource="http://onto.fairify.com#CodeSystem"/>
        <rdfs:label xml:lang="en">TNM classification system</rdfs:label>
        <rdfs:label xml:lang="nl">TNM-classificatiesysteem</rdfs:label>
        <skos:definition xml:lang="nl">De TNM-classificatie van maligne tumoren, beheerd door de UICC. T codeert primaire tumoruitbreiding (PrimaryTumourExtent), N codeert regionale lymfklierbetrokkenheid (RegionalLymphNodeInvolvement), M codeert verre metastasering (DistantMetastasis). Prefixen &apos;c&apos; en &apos;p&apos; corresponderen met respectievelijk ClinicalStagingProcess en PathologicalStagingProcess. Meerdere edities bestaan; de editie moet samen met de code worden vastgelegd.</skos:definition>
        <skos:definition xml:lang="en">The TNM Classification of Malignant Tumours, maintained by the Union for International Cancer Control (UICC). T encodes primary tumour extent (PrimaryTumourExtent), N encodes regional lymph node involvement (RegionalLymphNodeInvolvement), M encodes distant metastasis (DistantMetastasis). Prefixes &apos;c&apos; and &apos;p&apos; correspond to ClinicalStagingProcess and PathologicalStagingProcess respectively. Multiple editions exist (6, 7, 8); edition must be recorded alongside the code.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- http://onto.fairify.com#ZorgactiviteitCode -->

    <owl:NamedIndividual rdf:about="http://onto.fairify.com#ZorgactiviteitCode">
        <rdf:type rdf:resource="http://onto.fairify.com#CodeSystem"/>
        <rdfs:label xml:lang="en">zorgactiviteit code</rdfs:label>
        <rdfs:label xml:lang="nl">zorgactiviteitcode</rdfs:label>
        <skos:definition xml:lang="en">Dutch care activity code (zorgactiviteitcode) used in the DBC/DOT system to identify specific clinical activities.</skos:definition>
        <skos:definition xml:lang="nl">Nederlandse zorgactiviteitcode gebruikt in het DBC/DOT-systeem om specifieke klinische activiteiten te identificeren.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- http://onto.fairify.com#ZorgproductCode -->

    <owl:NamedIndividual rdf:about="http://onto.fairify.com#ZorgproductCode">
        <rdf:type rdf:resource="http://onto.fairify.com#CodeSystem"/>
        <rdfs:label xml:lang="en">zorgproduct code</rdfs:label>
        <rdfs:label xml:lang="nl">zorgproductcode</rdfs:label>
        <skos:definition xml:lang="en">Dutch care product code used in the DOT system to identify a care product (grouping of care activities).</skos:definition>
        <skos:definition xml:lang="nl">Nederlandse zorgproductcode gebruikt in het DOT-systeem om een zorgproduct (groepering van zorgactiviteiten) te identificeren.</skos:definition>
    </owl:NamedIndividual>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // PROM extension
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- http://onto.fairify.com#PROMInstrument -->

    <owl:Class rdf:about="http://onto.fairify.com#PROMInstrument">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">PROM instrument</rdfs:label>
        <rdfs:label xml:lang="nl">PROM instrument</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that defines the structure, questions, and scoring rules of a standardised self-report questionnaire used to collect patient-reported assessments of health, functioning, or quality of life. A PROM instrument is the template from which individual completed questionnaires (PatientReportedOutcomeMeasure) are produced.</skos:definition>
        <skos:definition xml:lang="nl">Een informatiecontententiteit die de structuur, vragen en scoringsregels definieert van een gestandaardiseerde zelfrapportagevragenlijst die wordt gebruikt om patiëntgerapporteerde beoordelingen van gezondheid, functioneren of kwaliteit van leven te verzamelen. Een PROM-instrument is het sjabloon waaruit individuele ingevulde vragenlijsten (PatientReportedOutcomeMeasure) worden geproduceerd.</skos:definition>
    </owl:Class>


    <!-- http://onto.fairify.com#PROMAdministration -->

    <owl:Class rdf:about="http://onto.fairify.com#PROMAdministration">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITAXON_9606"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002233"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#PROMInstrument"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002234"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#PatientReportedOutcomeMeasure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">PROM administration</rdfs:label>
        <rdfs:label xml:lang="nl">PROM afname</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a person completes a PROM instrument, producing a completed patient reported outcome measure as output. The person is the participant whose qualities are being assessed; they are not modelled as a patient role, since completing a questionnaire does not presuppose a care relationship. The PROM instrument is the input that structures the process. The temporal location of this process provides the measurement time, independently of any clinical intervention.</skos:definition>
        <skos:definition xml:lang="nl">Een gepland proces waarbij een persoon een PROM-instrument invult, met als uitkomst een ingevulde patiënt gerapporteerde uitkomstmaat. De persoon is de deelnemer wiens kwaliteiten worden beoordeeld; deze wordt niet gemodelleerd als patiëntrol, omdat het invullen van een vragenlijst geen zorgrelatie veronderstelt. Het PROM-instrument is de input die het proces structureert. De temporele locatie van dit proces levert het meetmoment, onafhankelijk van een klinische interventie.</skos:definition>
    </owl:Class>


    <!-- http://onto.fairify.com#QualityOfLife -->

    <owl:Class rdf:about="http://onto.fairify.com#QualityOfLife">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">quality of life</rdfs:label>
        <rdfs:label xml:lang="nl">kwaliteit van leven</rdfs:label>
        <skos:definition xml:lang="en">A quality inhering in a person that reflects their subjective assessment of their own physical, mental, and social well-being at a given point in time. Quality of life is not restricted to health-related aspects; the scope of assessment is determined by the instrument used to measure it. Multiple instruments (e.g. EQ-5D, SF-36, OHS) may measure different facets of this quality.</skos:definition>
        <skos:definition xml:lang="nl">Een kwaliteit die inhereert in een persoon en die hun subjectieve beoordeling weerspiegelt van hun eigen fysiek, mentaal en sociaal welbevinden op een bepaald tijdstip. Kwaliteit van leven is niet beperkt tot gezondheidsgebonden aspecten; de reikwijdte van de beoordeling wordt bepaald door het gebruikte meetinstrument. Meerdere instrumenten (bijv. EQ-5D, SF-36, OHS) kunnen verschillende facetten van deze kwaliteit meten.</skos:definition>
    </owl:Class>


    <!-- http://onto.fairify.com#EQ5DScore -->

    <owl:Class rdf:about="http://onto.fairify.com#EQ5DScore">
        <rdfs:subClassOf rdf:resource="http://onto.fairify.com#PROMScore"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://onto.fairify.com#QualityOfLife"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">EQ-5D score</rdfs:label>
        <rdfs:label xml:lang="nl">EQ-5D score</rdfs:label>
        <skos:definition xml:lang="en">A PROM score representing a summary assessment of quality of life as measured by the EQ-5D instrument. Covers the composite index score or VAS thermometer score derived from the EQ-5D questionnaire. Sub-dimension scores (mobility, self-care, usual activities, pain/discomfort, anxiety/depression) are modelled as parts of the containing PatientReportedOutcomeMeasure and are not separately subclassed here.</skos:definition>
        <skos:definition xml:lang="nl">Een PROM-score die een samengestelde beoordeling van kwaliteit van leven vertegenwoordigt zoals gemeten met het EQ-5D-instrument. Betreft de samengestelde indexscore of VAS-thermometerscore afgeleid van de EQ-5D-vragenlijst. Subdimensiescores (mobiliteit, zelfzorg, dagelijkse activiteiten, pijn/ongemak, angst/depressie) worden gemodelleerd als onderdelen van de bijbehorende PatientReportedOutcomeMeasure en worden hier niet apart geclassificeerd.</skos:definition>
    </owl:Class>


    <!-- Named individuals: PROM instruments -->


    <!-- http://onto.fairify.com#EQ-5D-3L -->

    <owl:NamedIndividual rdf:about="http://onto.fairify.com#EQ-5D-3L">
        <rdf:type rdf:resource="http://onto.fairify.com#PROMInstrument"/>
        <rdfs:label xml:lang="en">EQ-5D-3L</rdfs:label>
        <rdfs:label xml:lang="nl">EQ-5D-3L</rdfs:label>
        <skos:definition xml:lang="en">The EQ-5D-3L instrument, a standardised self-report questionnaire developed by the EuroQol Group measuring health-related quality of life across five dimensions (mobility, self-care, usual activities, pain/discomfort, anxiety/depression) each at three severity levels, plus a visual analogue scale (VAS thermometer). Widely used in Dutch MSZ transparency indicators for orthopaedic and other elective procedures.</skos:definition>
        <skos:definition xml:lang="nl">Het EQ-5D-3L instrument, een gestandaardiseerde zelfrapportagevragenlijst ontwikkeld door de EuroQol Groep die gezondheidsgerelateerde kwaliteit van leven meet op vijf dimensies (mobiliteit, zelfzorg, dagelijkse activiteiten, pijn/ongemak, angst/depressie) elk op drie ernstniveaus, plus een visuele analoge schaal (VAS-thermometer). Breed toegepast in Nederlandse MSZ-transparantie-indicatoren voor orthopedische en andere electieve ingrepen.</skos:definition>
    </owl:NamedIndividual>
</rdf:RDF>



