PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>
PREFIX obo:     <http://purl.obolibrary.org/obo/>
PREFIX time:    <http://www.w3.org/2006/time#>
PREFIX onto:    <https://w3id.org/zinl/ti-o#>


# Tel het aantal overleden personen in 2023
SELECT (COUNT(?patient) AS ?aantalOverleden)
{
    BIND(2023 AS ?jaar)
    BIND(STRDT(CONCAT(STR(?jaar),       "-01-01"), xsd:date) AS ?jaarStart)
    BIND(STRDT(CONCAT(STR(?jaar + 1),   "-01-01"), xsd:date) AS ?jaarEind)
    
    ?patient a obo:NCBITAXON_9606 ;
    	onto:hasDeathDate/time:inXSDDate ?datumOverlijden .
   
    FILTER ( ?datumOverlijden >= ?jaarStart && ?datum < ?jaarEind )
}
GROUP BY ?patient