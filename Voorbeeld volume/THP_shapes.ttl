#         ] ] ;
#         sh:qualifiedMinCount 1 ;
#         sh:name     "heeft deelnemer: fysieke afwijking (SNOMED CT)"@nl ;
#         sh:message  "Een THP moet minstens één fysieke afwijking als deelnemer hebben die aangeduid wordt door een SNOMED CT CRID."@nl ;
#     ] ;

#     # THP denoted by some CRID
#     sh:property [
#         sh:path     obo:IAO_0000235 ;
#         sh:class    obo:IAO_0000578 ;
#         sh:minCount 1 ;
#         sh:name     "aangeduid door CRID"@nl ;
#         sh:message  "Een THP moet aangeduid worden door minstens één CRID."@nl ;
#         sh:node     :CRIDShape ;
#     ] ;

#     # THP hasTime some TemporalEntity
#     sh:property [
#         sh:path     time:hasTime ;
#         sh:class    time:TemporalEntity ;
#         sh:minCount 1 ;
#         sh:name     "heeft tijdsaanduiding"@nl ;
#         sh:message  "Een THP moet gekoppeld zijn aan minstens één temporele entiteit via time:hasTime."@nl ;
#     ] ;

    # THP occurs_in some IndependentContinuant
    sh:property [
        sh:path     obo:BFO_0000066 ;
        sh:class    obo:BFO_0000004 ;
        sh:minCount 1 ;
        sh:name     "vindt plaats in: onafhankelijk continuant"@nl ;
        sh:message  "Een THP moet plaatsvinden in minstens één onafhankelijk continuant (bijv. een zorglocatie)."@nl ;
    ] .


