#         sh:name     "deel van codesysteem"@nl ;
#         sh:message  "Een CRID moet deel zijn van minstens één CodeSystem via BFO part_of."@nl ;
#     ] ;

#     sh:property [
#         sh:path     obo:IAO_0000577 ;
#         sh:datatype xsd:string ;
#         sh:minCount 1 ;
#         sh:name     "identifier symbool"@nl ;
#         sh:message  "Een CRID moet minstens één xsd:string symbool hebben via IAO_0000577."@nl ;
#     ] .


