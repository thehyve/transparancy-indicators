#         sh:qualifiedValueShape [ sh:class obo:OGMS_0000102 ] ;
#         sh:qualifiedMinCount 1 ;
#         sh:name     "heeft deelnemer: aandoening"@nl ;
#         sh:message  "Een THP moet minstens één Disorder als deelnemer hebben."@nl ;
#     ] ;

#     # THP has_participant some FysiekeAfwijking (OGMS_0000045)
