# ===========================================================================
# Shape: THP (Totale Heup Procedure)
# ===========================================================================

:THPShape
    a sh:NodeShape ;
    sh:targetClass ti-o:THP ;
    rdfs:label "Shape voor Totale Heup Procedure instances"@nl ;

#     # THP has_participant some Homo Sapiens
#     sh:property [
